# OS cruft
.DS_Store
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini

# Editor / agent local state
.vscode/
.idea/
.claude/

# Your decks live under presentations/ and are PRIVATE by default. This is a
# PUBLIC starter repo — your content (client names, numbers, the saved brief in
# notes.md) should never be committed to a clone of it. So everything under
# presentations/ is ignored, except the shipped example that shows the format.
#
# Want your own decks version-controlled? Keep them in a SEPARATE private repo
# and force-add past this rule:  git add -f presentations/<name>/deck.html
presentations/*
!presentations/example/

# PDF exports — regenerate any time from a deck via Print → Save as PDF.
presentations/**/*.pdf

# Review feedback is local, transient working state — once your agent has
# applied it, it's spent. Not part of the deck you share.
review.jsonl
presentations/**/review.jsonl
